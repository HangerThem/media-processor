generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String                       @id @default(cuid())
  name             String
  role             Role
  authUserId       String                       @unique @map("auth_user_id")
  createdAt        DateTime                     @default(now()) @map("created_at")
  updatedAt        DateTime                     @updatedAt @map("updated_at")
  lastSeenMessages LastSeenMessageInGroupChat[]
  seenComments     CommentSeenByUser[]
  comments         Comment[]
  companyContact   CompanyContact?
  uploadedFiles    File[]                       @relation("FileUploader")
  sentMessages     Message[]
  notes            Note[]
  staff            Staff?

  @@map("users")
}

model Company {
  id                  String             @id @default(cuid())
  name                String
  location            String?
  active              Boolean            @default(true)
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  avatarId            String?            @unique @map("avatar_id")
  groupChatId         String             @unique @map("groupchat_id")
  subscriptionPlanId  String?            @map("subscription_plan_id")
  businessAssociateId String?            @map("business_associate_id")
  photographerId      String?            @map("photographer_id")
  favorite            Boolean            @default(false)
  warning             Boolean            @default(false)
  avatar              File?              @relation("CompanyAvatar", fields: [avatarId], references: [id])
  businessAssociate   BusinessAssociate? @relation(fields: [businessAssociateId], references: [id])
  groupChat           GroupChat          @relation(fields: [groupChatId], references: [id])
  photographer        Photographer?      @relation(fields: [photographerId], references: [id])
  subscriptionPlan    SubscriptionPlan?  @relation(fields: [subscriptionPlanId], references: [id])
  companyContacts     CompanyContact?    @relation("CompanyContacts")
  files               File[]             @relation("CompanyFiles")
  folders             Folder[]
  notes               Note[]
  notifications       Notification[]
  photoshoots         Photoshoot[]
  plans               Plan[]
  staff               StaffCompany?

  @@map("companies")
}

model CompanyContact {
  id                 String              @id @default(cuid())
  isMainContact      Boolean             @default(false) @map("is_main_contact")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  userId             String              @unique @map("user_id")
  companyId          String              @unique(where: raw("(is_main_contact = true)")) @map("company_id")
  company            Company             @relation("CompanyContacts", fields: [companyId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  photoshootBookings PhotoshootBooking[]

  @@index([companyId])
  @@map("company_contacts")
}

model Staff {
  id        String         @id @default(cuid())
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  userId    String         @unique @map("user_id")
  avatarId  String?        @unique @map("avatar_id")
  avatar    File?          @relation("StaffAvatar", fields: [avatarId], references: [id])
  user      User           @relation(fields: [userId], references: [id])
  companies StaffCompany[]

  @@map("staff")
}

model StaffCompany {
  staffId   String   @map("staff_id")
  companyId String   @unique(where: raw("(is_admin = true)")) @map("company_id")
  createdAt DateTime @default(now()) @map("created_at")
  isAdmin   Boolean  @default(false) @map("is_admin")
  company   Company  @relation(fields: [companyId], references: [id])
  staff     Staff    @relation(fields: [staffId], references: [id])

  @@id([staffId, companyId])
  @@index([companyId])
  @@map("staff_companies")
}

model Note {
  id        String     @id @default(cuid())
  title     String
  content   String?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  companyId String?    @map("company_id")
  authorId  String     @map("author_id")
  noteFiles NoteFile[]
  author    User       @relation(fields: [authorId], references: [id])
  company   Company?   @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([authorId])
  @@map("notes")
}

model Notification {
  id        String            @id @default(cuid())
  title     String
  content   String
  link      String?
  type      NotificationType
  scope     NotificationScope
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  companyId String?           @map("company_id")
  company   Company?          @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([scope])
  @@map("notifications")
}

model Plan {
  id             String    @id @default(cuid())
  published      Boolean   @default(false)
  publishingWeek DateTime? @map("publishing_week")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  companyId      String    @map("company_id")
  company        Company   @relation(fields: [companyId], references: [id])
  posts          Post[]

  @@index([companyId])
  @@index([publishingWeek])
  @@map("plans")
}

model Post {
  id             String     @id @default(cuid())
  published      Boolean    @default(false)
  publishingDate DateTime?  @map("publishing_date")
  caption        String?
  type           PostType
  approved       Boolean    @default(false)
  platforms      Platform[]
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  planId         String     @map("plan_id")
  comments       Comment[]
  postFiles      PostFile[]
  plan           Plan       @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([publishingDate])
  @@index([approved])
  @@map("posts")
}

model Comment {
  id        String              @id @default(cuid())
  content   String
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  authorId  String              @map("author_id")
  postId    String              @map("post_id")
  seenBy    CommentSeenByUser[]
  author    User                @relation(fields: [authorId], references: [id])
  post      Post                @relation(fields: [postId], references: [id])

  @@index([postId])
  @@index([authorId])
  @@map("comments")
}

model CommentSeenByUser {
  userId    String   @map("user_id")
  commentId String   @map("comment_id")
  seenAt    DateTime @default(now()) @map("seen_at")
  comment   Comment  @relation(fields: [commentId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, commentId])
  @@index([commentId])
  @@map("comment_seen_by_user")
}

model File {
  id              String           @id @default(cuid())
  name            String
  mimeType        String           @map("mime_type")
  type            FileType
  status          FileStatus       @default(pending)
  size            Int
  width           Int?
  height          Int?
  duration        Int?
  storagePath     String           @map("storage_path")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  uploaderId      String           @map("uploader_id")
  companyId       String?          @map("company_id")
  folderId        String?          @map("folder_id")
  companyAvatar   Company?         @relation("CompanyAvatar")
  fileDerivatives FileDerivative[]
  company         Company?         @relation("CompanyFiles", fields: [companyId], references: [id])
  folder          Folder?          @relation(fields: [folderId], references: [id])
  uploader        User             @relation("FileUploader", fields: [uploaderId], references: [id])
  messageFiles    MessageFile[]
  noteFiles       NoteFile[]
  postFiles       PostFile[]
  staffAvatar     Staff?           @relation("StaffAvatar")

  @@index([companyId])
  @@index([folderId])
  @@index([uploaderId])
  @@index([type])
  @@index([status])
  @@map("files")
}

model FileDerivative {
  id          String         @id @default(cuid())
  type        DerivativeType
  storagePath String         @map("storage_path")
  mimeType    String         @map("mime_type")
  size        Int
  width       Int?
  height      Int?
  duration    Int?
  status      FileStatus     @default(pending)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  sourceId    String         @map("source_id")
  source      File           @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, type])
  @@index([sourceId])
  @@map("file_derivatives")
}

model PostFile {
  postId    String   @map("post_id")
  fileId    String   @map("file_id")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  file      File     @relation(fields: [fileId], references: [id])
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, fileId])
  @@index([postId])
  @@map("post_files")
}

model MessageFile {
  messageId String   @map("message_id")
  fileId    String   @map("file_id")
  createdAt DateTime @default(now()) @map("created_at")
  file      File     @relation(fields: [fileId], references: [id])
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([messageId, fileId])
  @@index([messageId])
  @@map("message_files")
}

model NoteFile {
  noteId    String   @map("note_id")
  fileId    String   @map("file_id")
  createdAt DateTime @default(now()) @map("created_at")
  file      File     @relation(fields: [fileId], references: [id])
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@id([noteId, fileId])
  @@index([noteId])
  @@map("note_files")
}

model Folder {
  id          String   @id @default(cuid())
  name        String
  storagePath String   @map("storage_path")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  companyId   String   @map("company_id")
  files       File[]
  company     Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@map("folders")
}

model GroupChat {
  id        String                       @id @default(cuid())
  createdAt DateTime                     @default(now()) @map("created_at")
  updatedAt DateTime                     @updatedAt @map("updated_at")
  lastSeen  LastSeenMessageInGroupChat[]
  company   Company?
  messages  Message[]

  @@map("group_chats")
}

model Message {
  id           String                       @id @default(cuid())
  content      String?
  createdAt    DateTime                     @default(now()) @map("created_at")
  updatedAt    DateTime                     @updatedAt @map("updated_at")
  senderId     String                       @map("sender_id")
  groupChatId  String                       @map("groupchat_id")
  lastSeenBy   LastSeenMessageInGroupChat[]
  messageFiles MessageFile[]
  groupChat    GroupChat                    @relation(fields: [groupChatId], references: [id])
  sender       User                         @relation(fields: [senderId], references: [id])

  @@index([groupChatId])
  @@index([senderId])
  @@index([createdAt])
  @@map("messages")
}

model LastSeenMessageInGroupChat {
  userId      String    @map("user_id")
  groupChatId String    @map("group_chat_id")
  messageId   String    @map("message_id")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  groupChat   GroupChat @relation(fields: [groupChatId], references: [id])
  message     Message   @relation(fields: [messageId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@id([userId, groupChatId])
  @@index([groupChatId])
  @@map("chat_read_state")
}

model Photoshoot {
  id             String             @id @default(cuid())
  date           DateTime           @db.Date
  segment        PhotoshootTime
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  companyId      String             @map("company_id")
  photographerId String?            @map("photographer_id")
  bookings       PhotoshootBooking?
  company        Company            @relation(fields: [companyId], references: [id])
  photographer   Photographer?      @relation(fields: [photographerId], references: [id])

  @@unique([companyId, date, segment])
  @@index([companyId])
  @@map("photoshoots")
}

model PhotoshootBooking {
  id           String         @id @default(cuid())
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  bookedById   String         @map("booked_by_id")
  photoshootId String         @unique @map("photoshoot_id")
  bookedBy     CompanyContact @relation(fields: [bookedById], references: [id])
  photoshoot   Photoshoot     @relation(fields: [photoshootId], references: [id])

  @@index([bookedById])
  @@map("photoshoot_bookings")
}

model SubscriptionPlan {
  id        String    @id @default(cuid())
  name      String
  price     Decimal   @db.Decimal(10, 2)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  companies Company[]

  @@map("subscription_plans")
}

model Photographer {
  id          String       @id @default(cuid())
  name        String
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  companies   Company[]
  photoshoots Photoshoot[]

  @@map("photographers")
}

model BusinessAssociate {
  id        String    @id @default(cuid())
  name      String
  phone     String
  email     String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  companies Company[]

  @@map("business_associates")
}

enum Role {
  staff
  company_contact
  admin
}

enum Platform {
  facebook
  instagram
}

enum PostType {
  story
  reel
  feed
}

enum NotificationType {
  post
  folder
  document
  photoshoot
  other
}

enum NotificationScope {
  global
  company
}

enum FileType {
  image
  video
  document
  other
}

enum FileStatus {
  pending
  processing
  done
  failed
}

enum DerivativeType {
  thumbnail
  preview
  hd
  compressed
  gif_preview
}

enum PhotoshootTime {
  morning
  noon
  afternoon
}
