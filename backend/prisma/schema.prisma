generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                           String                       @id @default(cuid())
  name                         String
  email                        String                       @unique
  phone                        String?
  role                         Role
  authUserId                   String                       @unique @map("auth_user_id") @db.Uuid
  createdAt                    DateTime                     @default(now()) @map("created_at")
  updatedAt                    DateTime                     @updatedAt @map("updated_at")
  avatar_id                    String?                      @unique
  bookmarks                    bookmarks[]
  business_associates          BusinessAssociate?
  chat_participants            chat_participants[]
  lastSeenMessages             LastSeenMessageInGroupChat[]
  client_contacts              client_contacts?
  seenComments                 CommentSeenByUser[]
  comments                     Comment[]
  uploadedFiles                File[]                       @relation("FileUploader")
  managers                     managers?
  sentMessages                 Message[]
  notes                        Note[]
  photographers                Photographer?
  files_users_avatar_idTofiles File?                        @relation("users_avatar_idTofiles", fields: [avatar_id], references: [id])

  @@index([email])
  @@map("users")
}

model Note {
  id        String     @id @default(cuid())
  title     String
  content   String?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  client_id String?
  authorId  String     @map("author_id")
  noteFiles NoteFile[]
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  clients   clients?   @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([client_id])
  @@map("notes")
}

model Notification {
  id        String            @id @default(cuid())
  title     String
  content   String
  link      String?
  type      NotificationType
  scope     NotificationScope
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  client_id String?
  clients   clients?          @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([scope])
  @@index([client_id])
  @@map("notifications")
}

model Plan {
  id             String    @id @default(cuid())
  published      Boolean   @default(false)
  publishingWeek DateTime? @map("publishing_week")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  client_id      String
  clients        clients   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  posts          Post[]

  @@index([publishingWeek])
  @@index([client_id])
  @@map("plans")
}

model Post {
  id             String     @id @default(cuid())
  published      Boolean    @default(false)
  publishingDate DateTime?  @map("publishing_date")
  caption        String?
  type           PostType
  approved       Boolean    @default(false)
  platforms      Platform[]
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  planId         String     @map("plan_id")
  comments       Comment[]
  postFiles      PostFile[]
  plan           Plan       @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([publishingDate])
  @@index([approved])
  @@map("posts")
}

model Comment {
  id        String              @id @default(cuid())
  content   String
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  authorId  String              @map("author_id")
  postId    String              @map("post_id")
  seenBy    CommentSeenByUser[]
  author    User                @relation(fields: [authorId], references: [id])
  post      Post                @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
  @@map("comments")
}

model CommentSeenByUser {
  userId    String   @map("user_id")
  commentId String   @map("comment_id")
  seenAt    DateTime @default(now()) @map("seen_at")
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])
  @@map("comment_seen_by_user")
}

model File {
  id                                          String           @id @default(cuid())
  name                                        String
  mimeType                                    String           @map("mime_type")
  type                                        FileType
  status                                      FileStatus       @default(pending)
  size                                        Int
  width                                       Int?
  height                                      Int?
  duration                                    Int?
  storagePath                                 String           @map("storage_path")
  createdAt                                   DateTime         @default(now()) @map("created_at")
  updatedAt                                   DateTime         @updatedAt @map("updated_at")
  uploaderId                                  String           @map("uploader_id")
  client_id                                   String?
  bookmarks_bookmarks_book_document_idTofiles bookmarks?       @relation("bookmarks_book_document_idTofiles")
  bookmarks_bookmarks_book_poster_idTofiles   bookmarks?       @relation("bookmarks_book_poster_idTofiles")
  client_files                                client_files[]
  clients_clients_avatar_idTofiles            clients?         @relation("clients_avatar_idTofiles")
  fileDerivatives                             FileDerivative[]
  clients_files_client_idToclients            clients?         @relation("files_client_idToclients", fields: [client_id], references: [id])
  uploader                                    User             @relation("FileUploader", fields: [uploaderId], references: [id])
  folder_files                                folder_files[]
  messageFiles                                MessageFile[]
  noteFiles                                   NoteFile[]
  postFiles                                   PostFile[]
  users_users_avatar_idTofiles                User?            @relation("users_avatar_idTofiles")

  @@index([uploaderId])
  @@index([type])
  @@index([status])
  @@index([client_id])
  @@map("files")
}

model FileDerivative {
  id          String         @id @default(cuid())
  type        DerivativeType
  storagePath String         @map("storage_path")
  mimeType    String         @map("mime_type")
  size        Int
  width       Int?
  height      Int?
  duration    Int?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  sourceId    String         @map("source_id")
  source      File           @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, type])
  @@index([sourceId])
  @@map("file_derivatives")
}

model PostFile {
  postId    String   @map("post_id")
  fileId    String   @map("file_id")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  file      File     @relation(fields: [fileId], references: [id])
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([postId, fileId])
  @@index([postId])
  @@map("post_files")
}

model MessageFile {
  messageId String   @map("message_id")
  fileId    String   @map("file_id")
  createdAt DateTime @default(now()) @map("created_at")
  file      File     @relation(fields: [fileId], references: [id])
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([messageId, fileId])
  @@index([messageId])
  @@map("message_files")
}

model NoteFile {
  noteId    String   @map("note_id")
  fileId    String   @map("file_id")
  createdAt DateTime @default(now()) @map("created_at")
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@id([noteId, fileId])
  @@index([noteId])
  @@map("note_files")
}

model Folder {
  id           String         @id @default(cuid())
  name         String
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  client_id    String
  folder_files folder_files[]
  clients      clients        @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@index([client_id])
  @@map("folders")
}

model Message {
  id             String                       @id @default(cuid())
  content        String?
  createdAt      DateTime                     @default(now()) @map("created_at")
  updatedAt      DateTime                     @updatedAt @map("updated_at")
  senderId       String                       @map("sender_id")
  chat_id        String
  reply_to_id    String?
  lastSeenBy     LastSeenMessageInGroupChat[]
  messageFiles   MessageFile[]
  chats          chats                        @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  messages       Message?                     @relation("messagesTomessages", fields: [reply_to_id], references: [id])
  other_messages Message[]                    @relation("messagesTomessages")
  sender         User                         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([createdAt])
  @@index([chat_id])
  @@index([reply_to_id])
  @@map("messages")
}

model LastSeenMessageInGroupChat {
  userId    String   @map("user_id")
  chat_id   String
  messageId String   @map("message_id")
  updatedAt DateTime @updatedAt @map("updated_at")
  chats     chats    @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, chat_id])
  @@index([chat_id])
  @@map("chat_read_state")
}

model Photoshoot {
  id             String             @id @default(cuid())
  date           DateTime           @db.Date
  segment        PhotoshootTime
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  client_id      String
  photographerId String?            @map("photographer_id")
  bookings       PhotoshootBooking?
  clients        clients            @relation(fields: [client_id], references: [id], onDelete: Cascade)
  photographer   Photographer?      @relation(fields: [photographerId], references: [id])

  @@unique([client_id, date, segment])
  @@index([client_id])
  @@map("photoshoots")
}

model PhotoshootBooking {
  id           String          @id @default(cuid())
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  bookedById   String          @map("booked_by_id")
  photoshootId String          @unique @map("photoshoot_id")
  bookedBy     client_contacts @relation(fields: [bookedById], references: [id], onDelete: Cascade)
  photoshoot   Photoshoot      @relation(fields: [photoshootId], references: [id], onDelete: Cascade)

  @@index([bookedById])
  @@map("photoshoot_bookings")
}

model SubscriptionPlan {
  id        String    @id @default(cuid())
  name      String
  price     Int
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  clients   clients[]

  @@map("subscription_plans")
}

model Photographer {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  user_id     String       @unique
  clients     clients[]
  users       User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  photoshoots Photoshoot[]

  @@map("photographers")
}

model BusinessAssociate {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user_id   String    @unique
  users     User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  clients   clients[]

  @@map("business_associates")
}

model bookmarks {
  id                                      String   @id
  title                                   String
  description                             String?
  published                               Boolean  @default(false)
  created_at                              DateTime @default(now())
  updated_at                              DateTime
  author_id                               String
  book_document_id                        String?  @unique
  book_poster_id                          String?  @unique
  users                                   User     @relation(fields: [author_id], references: [id])
  files_bookmarks_book_document_idTofiles File?    @relation("bookmarks_book_document_idTofiles", fields: [book_document_id], references: [id])
  files_bookmarks_book_poster_idTofiles   File?    @relation("bookmarks_book_poster_idTofiles", fields: [book_poster_id], references: [id])
}

model chat_participants {
  user_id   String
  chat_id   String
  joined_at DateTime @default(now())
  chats     chats    @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  users     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, chat_id])
  @@index([chat_id])
  @@index([user_id])
}

model chats {
  id                String                       @id
  name              String?
  key               String?                      @unique
  type              ChatType                     @default(group)
  created_at        DateTime                     @default(now())
  updated_at        DateTime
  chat_participants chat_participants[]
  chat_read_state   LastSeenMessageInGroupChat[]
  clients           clients?
  messages          Message[]
}

model client_contacts {
  id                 String              @id
  is_main_contact    Boolean             @default(false)
  created_at         DateTime            @default(now())
  updated_at         DateTime
  user_id            String              @unique
  client_id          String              @unique(where: raw("(is_main_contact = true)"))
  clients            clients             @relation(fields: [client_id], references: [id], onDelete: Cascade)
  users              User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  photoshootBookings PhotoshootBooking[]

  @@index([client_id])
}

model clients {
  id                             String             @id
  name                           String
  location                       String?
  active                         Boolean            @default(true)
  favorite                       Boolean            @default(false)
  warning                        Boolean            @default(false)
  created_at                     DateTime           @default(now())
  updated_at                     DateTime
  avatar_id                      String?            @unique
  chat_id                        String             @unique
  subscription_plan_id           String?
  business_associate_id          String?
  photographer_id                String?
  client_contacts                client_contacts?
  client_files                   client_files[]
  files_clients_avatar_idTofiles File?              @relation("clients_avatar_idTofiles", fields: [avatar_id], references: [id])
  business_associates            BusinessAssociate? @relation(fields: [business_associate_id], references: [id])
  chats                          chats              @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  photographers                  Photographer?      @relation(fields: [photographer_id], references: [id])
  subscription_plans             SubscriptionPlan?  @relation(fields: [subscription_plan_id], references: [id])
  files_files_client_idToclients File[]             @relation("files_client_idToclients")
  folders                        Folder[]
  manager_clients                manager_clients?
  notes                          Note[]
  notifications                  Notification[]
  photoshoots                    Photoshoot[]
  plans                          Plan[]
}

model manager_clients {
  manager_id String
  client_id  String   @unique(where: raw("(is_admin = true)"))
  created_at DateTime @default(now())
  is_admin   Boolean  @default(false)
  clients    clients  @relation(fields: [client_id], references: [id], onDelete: Cascade)
  managers   managers @relation(fields: [manager_id], references: [id], onDelete: Cascade)

  @@id([manager_id, client_id])
  @@index([client_id])
}

model managers {
  id              String            @id
  location        String?
  note            String?
  created_at      DateTime          @default(now())
  updated_at      DateTime
  user_id         String            @unique
  manager_clients manager_clients[]
  users           User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model client_files {
  client_id  String
  file_id    String
  created_at DateTime @default(now())
  clients    clients  @relation(fields: [client_id], references: [id], onDelete: Cascade)
  files      File     @relation(fields: [file_id], references: [id], onDelete: Cascade)

  @@id([client_id, file_id])
  @@index([client_id])
}

model folder_files {
  folder_id  String
  file_id    String
  created_at DateTime @default(now())
  files      File     @relation(fields: [file_id], references: [id], onDelete: Cascade)
  folders    Folder   @relation(fields: [folder_id], references: [id], onDelete: Cascade)

  @@id([folder_id, file_id])
  @@index([folder_id])
}

enum Role {
  admin
  manager
  photographer
  business_associate
  client_contact
}

enum Platform {
  facebook
  instagram
}

enum PostType {
  story
  reel
  feed
}

enum NotificationType {
  post
  folder
  document
  photoshoot
  other
}

enum NotificationScope {
  global
  client
}

enum FileType {
  image
  video
  document
  other
}

enum FileStatus {
  pending
  processing
  completed
  failed
}

enum DerivativeType {
  thumbnail
  preview
}

enum PhotoshootTime {
  morning
  noon
  afternoon
}

enum ChatType {
  direct
  group
}
